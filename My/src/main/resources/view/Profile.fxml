<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controller.ProfileController"
      style="-fx-background-color: #1a1a2e;"
      spacing="0">
    <HBox style="-fx-background-color: #0f3460; -fx-padding: 15 20;"
          alignment="CENTER_LEFT" spacing="15">
        <Button text="←" onAction="#handleBack"
                style="-fx-background-color: transparent;
                       -fx-text-fill: white;
                       -fx-font-size: 18px;
                       -fx-cursor: hand;
                       -fx-border-width: 0;"/>
        <Label text="Редагування профілю"
               style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
    </HBox>
    <VBox alignment="CENTER" spacing="10"
          style="-fx-background-color: #16213e; -fx-padding: 30 0;">
        <StackPane>
            <Circle fx:id="avatarCircle" radius="50"
                    style="-fx-fill: #e94560;"/>
            <Label fx:id="avatarInitial"
                   style="-fx-text-fill: white; -fx-font-size: 36px; -fx-font-weight: bold;"/>
        </StackPane>
        <Button text="Змінити колір аватарки" onAction="#handleChangeColor"
                style="-fx-background-color: transparent;
                       -fx-text-fill: #4ecca3;
                       -fx-font-size: 13px;
                       -fx-cursor: hand;
                       -fx-border-width: 0;"/>
        <HBox fx:id="colorPicker" alignment="CENTER" spacing="10"
              style="-fx-padding: 5 0;" visible="false" managed="false">
            <Circle radius="15" style="-fx-fill: #e94560; -fx-cursor: hand;"
                    onMouseClicked="#selectColor"/>
            <Circle radius="15" style="-fx-fill: #4ecca3; -fx-cursor: hand;"
                    onMouseClicked="#selectColor"/>
            <Circle radius="15" style="-fx-fill: #f5a623; -fx-cursor: hand;"
                    onMouseClicked="#selectColor"/>
            <Circle radius="15" style="-fx-fill: #7b68ee; -fx-cursor: hand;"
                    onMouseClicked="#selectColor"/>
            <Circle radius="15" style="-fx-fill: #ff6b6b; -fx-cursor: hand;"
                    onMouseClicked="#selectColor"/>
            <Circle radius="15" style="-fx-fill: #48dbfb; -fx-cursor: hand;"
                    onMouseClicked="#selectColor"/>
        </HBox>
    </VBox>
    <VBox style="-fx-background-color: #1a1a2e; -fx-padding: 20 25;" spacing="5">
        <Label text="ІМ'Я"
               style="-fx-text-fill: #4ecca3; -fx-font-size: 11px; -fx-font-weight: bold;"/>
        <TextField fx:id="nameField"
                   style="-fx-background-color: #16213e;
                          -fx-text-fill: white;
                          -fx-font-size: 14px;
                          -fx-padding: 10 15;
                          -fx-background-radius: 8;
                          -fx-border-width: 0;"/>
        <Label text="" style="-fx-padding: 5 0;"/>
        <Label text="ЮЗЕРНЕЙМ"
               style="-fx-text-fill: #4ecca3; -fx-font-size: 11px; -fx-font-weight: bold;"/>
        <TextField fx:id="usernameField"
                   style="-fx-background-color: #16213e;
                          -fx-text-fill: white;
                          -fx-font-size: 14px;
                          -fx-padding: 10 15;
                          -fx-background-radius: 8;
                          -fx-border-width: 0;"/>
        <Label text="Юзернейм може містити a-z, 0-9 та підкреслення"
               style="-fx-text-fill: #888; -fx-font-size: 11px;"/>
        <Label text="" style="-fx-padding: 5 0;"/>
        <Label text="ОПИС"
               style="-fx-text-fill: #4ecca3; -fx-font-size: 11px; -fx-font-weight: bold;"/>
        <TextArea fx:id="bioField"
                  prefRowCount="3"
                  style="-fx-background-color: #16213e;
                         -fx-text-fill: white;
                         -fx-font-size: 14px;
                         -fx-padding: 10 15;
                         -fx-background-radius: 8;
                         -fx-border-width: 0;"/>
        <Label text="Розкажи про себе"
               style="-fx-text-fill: #888; -fx-font-size: 11px;"/>
        <Label text="" style="-fx-padding: 5 0;"/>
        <Label fx:id="statusLabel" style="-fx-font-size: 12px;"/>
        <Button text="Зберегти" onAction="#handleSave"
                maxWidth="Infinity"
                style="-fx-background-color: #4ecca3;
                       -fx-text-fill: #1a1a2e;
                       -fx-font-size: 14px;
                       -fx-font-weight: bold;
                       -fx-padding: 12;
                       -fx-background-radius: 8;
                       -fx-cursor: hand;
                       -fx-border-width: 0;"/>
    </VBox>
</VBox>